# OpenRouter (story clustering embeddings)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_REFERER=https://sapu.local

## Admin Password
ADMIN_PASSWORD=sapu123

# Database Configuration
DATABASE_URL=postgresql://postgres@localhost:5432/sapu

# RabbitMQ
# Include credentials and vhost to match local RabbitMQ config
# Default user: acq / sapu123, vhost: /sapu
RABBITMQ_URL=amqp://sapu:sapu123@localhost:5672/sapu
QUEUE_MAX_RETRIES=3
QUEUE_CONNECT_COOLDOWN_MS=30000
QUEUE_PUBLISH_WARN_COOLDOWN_MS=10000
QUEUE_PREFETCH=1

# Server
PORT=3000
# CORS: comma-separated allow-list (e.g. "https://admin.sapu.io,https://app.sapu.io").
# Leave empty to disable CORS. DO NOT use * in production — it bypasses HMAC admin auth.
CORS_ORIGIN=
HEARTBEAT_TTL_MS=30000
FILE_CONFIG_DIR=./config/sites

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Admin panel auth
VITE_ADMIN_PASSWORD=sapu123

# x402 stateless extraction API
X402_HTTP_TIMEOUT_MS=8000
X402_BROWSER_TIMEOUT_MS=20000
X402_MAX_HTTP_BYTES=1500000

# x402 payment gate.
# Disabled by default for local dev. Set true in production after X402_PAY_TO is configured.
X402_ENABLED=false
X402_PAY_TO=0xYourSellerWalletAddress
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_RESOURCE_BASE_URL=https://sapu.rekursa.id
X402_SERVICE_NAME=Sapu Extract API
X402_MAX_TIMEOUT_SECONDS=120

# Browser backend: local-puppeteer for now. Cloudflare Browser Run can be wired
# behind the same /x402/fetch/browser response contract.
SAPU_BROWSER_BACKEND=local-puppeteer
CLOUDFLARE_BROWSER_HOUR_COST_USD=0.09

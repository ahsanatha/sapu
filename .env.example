## Admin Password
ADMIN_PASSWORD=acq123

# Database Configuration
DATABASE_URL=postgresql://postgres@localhost:5432/acq_v3

# RabbitMQ
# Include credentials and vhost to match local RabbitMQ config
# Default user: acq / acq123, vhost: /acq
RABBITMQ_URL=amqp://acq:acq123@localhost:5672/acq
QUEUE_MAX_RETRIES=3
QUEUE_CONNECT_COOLDOWN_MS=30000
QUEUE_PUBLISH_WARN_COOLDOWN_MS=10000
QUEUE_PREFETCH=1

# Server
PORT=3000
CORS_ORIGIN=*
HEARTBEAT_TTL_MS=30000
FILE_CONFIG_DIR=./config/sites

# Scraping
HEADLESS=true
STEALTH_MODE=true
TIMEOUT=30000
CONCURRENT_JOBS=5

# Scheduler
SCHEDULER_ENABLED=true
DEFAULT_CRON=0 */6 * * *

# Auto-scaling configuration
AUTO_SCALE_ENABLED=true
AUTO_SCALE_MIN_WORKERS=1
AUTO_SCALE_MAX_WORKERS=5
AUTO_SCALE_SCALE_UP_THRESHOLD=10
AUTO_SCALE_SCALE_DOWN_THRESHOLD=2
AUTO_SCALE_CHECK_INTERVAL=30000
AUTO_SCALE_SCALE_INTERVAL=60000
AUTO_SCALE_COOLDOWN=300000

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_TIMEOUT=30000

VITE_ADMIN_PASSWORD=acq123
VITE_API_ORIGIN=http://localhost:3000

# Admin panel auth token (used as cookie name + bearer)
ADMIN_ACCESS_TOKEN=change-me-in-env

{
  "id": "0090e5d0-8a80-4f34-b75d-175634521aea",
  "name": "liputan6",
  "base_url": "https://www.liputan6.com",
  "enabled": true,
  "config": {
    "scraping": {
      "timezone": "Asia/Jakarta",
      "page_load": {
        "timeout": 30000,
        "wait_until": "networkidle2"
      },
      "selectors": {
        "title": [
          "h1.read-page--header--title.entry-title"
        ],
        "content": [
          "div.article-content-body__item-content p",
          "div.article-content-body__item-content",
          "div.read-page--content"
        ],
        "publish_time": [
          "span.read-page-box__author__updated",
          "div.read-page-box__author__datetime",
          "meta[property='article:published_time']"
        ]
      },
      "publish_time": {
        "required": true,
        "raw_fallback": true,
        "enforce_rfc3339": false
      },
      "extract_links": false,
      "accept_language": "id",
      "follow_patterns": [],
      "exclude_patterns": [],
      "navigator_language": "id",
      "navigator_languages": [
        "id"
      ]
    },
    "classification": {
      "article_patterns": [
        "regex:^https?://(www\\.)?liputan6\\.com/[a-z0-9-]+/read/\\d+(/.*)?$"
      ],
      "exclude_patterns": []
    },
    "url_collection": {
      "enabled": false,
      "max_depth": 1,
      "page_load": {
        "timeout": 60000,
        "wait_until": "networkidle2",
        "use_shared_browser": true
      },
      "index_patterns": [
        "/",
        "/indeks",
        "/index",
        "/news",
        "/latest"
      ],
      "max_found_urls": 500,
      "index_match_type": "prefix",
      "max_urls_per_run": 100,
      "max_links_on_page": 200,
      "dedupe_ttl_minutes": 60,
      "max_collected_urls": 200,
      "respect_robots_txt": true,
      "max_index_jobs_urls": 100,
      "max_index_pages_per_run": 5,
      "robots_disallow_patterns": [
        "/privacy",
        "/auth",
        "/login"
      ]
    },
    "duplicate_prevention": {
      "check_url": true,
      "check_existing_articles": true
    }
  }
}
{
  "name": "sapu",
  "version": "3.0.0",
  "description": "Sapu - Ultra-Simple Configuration-Driven Architecture",
  "main": "dist/apis/server.js",
  "type": "module",
  "engines": {
    "node": "22.14.x",
    "pnpm": ">=10.24.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/apis/server.js",
    "dev": "tsx apis/main.ts",
    "worker": "tsx core/worker.ts",
    "api": "node dist/apis/server.js",
    "server": "node dist/apis/server.js",
    "db:init": "tsx core/tools/init-db.ts",
    "test:int-collect-scrape": "tsx core/tests/int-collect-and-scrape.ts",
    "web:dev": "pnpm --prefix web run dev",
    "web:build": "pnpm --prefix web run build",
    "web:preview": "pnpm --prefix web run preview -- --strictPort --port 4321",
    "app:dev": "pnpm --prefix mobile run start",
    "app:android": "pnpm --prefix mobile run android",
    "app:ios": "pnpm --prefix mobile run ios",
    "app:web": "pnpm --prefix mobile run web",
    "app:build:android": "pnpm --prefix mobile exec eas build --platform android",
    "app:build:ios": "pnpm --prefix mobile exec eas build --platform ios",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 1000"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.0",
    "amqplib": "0.10.0",
    "dotenv": "16.4.5",
    "express": "4.18.0",
    "node-cron": "3.0.0",
    "pg": "8.11.0",
    "puppeteer": "24.29.1"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.0",
    "@types/express": "4.17.0",
    "@types/node": "20.19.0",
    "@types/node-cron": "3.0.0",
    "@types/pg": "8.10.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "autoprefixer": "10.4.20",
    "esbuild": "0.27.0",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-jsx-a11y": "6.9.0",
    "postcss": "8.4.47",
    "tsx": "4.0.0",
    "typescript": "5.3.3"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}

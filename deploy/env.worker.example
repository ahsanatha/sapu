# Worker VM env file (copy to .env on VM-B)
# Same DB/RabbitMQ credentials as VM-A so the worker can authenticate.
# CONTROL_PLANE_HOST is VM-A's private Hetzner network IP (e.g. 10.0.0.1).

CONTROL_PLANE_HOST=10.0.0.1

# Postgres (must match control-plane)
POSTGRES_DB=sapu
POSTGRES_USER=sapu
POSTGRES_PASSWORD=<same-as-control-plane>

# RabbitMQ (must match control-plane)
RABBITMQ_USER=sapu
RABBITMQ_PASSWORD=<same-as-control-plane>
RABBITMQ_VHOST=sapu

# Worker tuning
WORKER_ID=worker-1
QUEUE_PREFETCH=5

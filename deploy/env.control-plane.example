# Control plane VM env file (copy to .env on VM-A)
# All values must be set; no defaults baked in.

# Postgres
POSTGRES_DB=sapu
POSTGRES_USER=sapu
POSTGRES_PASSWORD=<strong-random-32-chars>

# RabbitMQ
RABBITMQ_USER=sapu
RABBITMQ_PASSWORD=<strong-random-32-chars>
RABBITMQ_VHOST=sapu

# Admin auth (HMAC-SHA256 over ts:method:path with this password)
ADMIN_PASSWORD=<strong-random-32-chars>
ADMIN_ACCESS_TOKEN=<strong-random-32-chars>

# OpenRouter (story clustering embeddings)
OPENROUTER_API_KEY=sk-or-v1-<your-key>
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_REFERER=https://your-domain.example
